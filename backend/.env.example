SECRET_KEY=
SESSION_DURATION_MINUTES=30
CORS_ORIGINS=https://cisternas-api-wqac.onrender.com,null
MAX_UPLOAD_BYTES=5242880

# Para desarrollo local, deja DATABASE_URL vacio y se usara instance/cisternas.db.
# Para produccion, usa PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@host:5432/cisternas
DATABASE_URL=

# Usuarios iniciales. Solo se aplican la primera vez que se crea la base.
# Use contrasenas largas y unicas. No use admin123/usuario123/cliente123.
ADMIN_PASSWORD=
USER_PASSWORD=
CLIENT_PASSWORD=
